# ============================================
# Sowel Cloudspace - Environment Variables
# ============================================
# Copy this file to .env and replace every CHANGE_ME value.
# Never commit .env because it contains secrets.

# ---- GENERAL ----
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- DATABASE ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
POSTGRES_DB=cloudapp

# The init script creates auth_db and task_db inside the db container.
AUTH_DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_DATABASE_PASSWORD@db:5432/auth_db
TASK_DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_DATABASE_PASSWORD@db:5432/task_db

# ---- AUTH / JWT ----
SECRET_KEY=CHANGE_ME_RANDOM_STRING_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_SERVICE_URL=http://auth-service:8001

# ---- CORS ----
# Use comma-separated origins. In production, replace with the real frontend URL.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost,http://localhost:8080

# ---- FRONTEND ----
# Local default gateway:
# - docker-compose.yml: http://localhost
# - docker-compose.dev.yml: http://localhost:8080
VITE_API_URL=http://localhost
