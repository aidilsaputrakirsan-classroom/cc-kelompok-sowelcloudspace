# ==================== Environment ====================
# "development" atau "production"
ENV=development

# ==================== Database ====================
# Ganti localhost menjadi host.docker.internal untuk akses dari dalam Docker
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sowel_task

# ==================== JWT ====================
SECRET_KEY=your-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==================== CORS ====================
# Pisahkan dengan koma untuk multiple origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== Logging ====================
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# ==================== Debug & Docs ====================
# Set "false" di production
DEBUG=true
DOCS_ENABLED=true